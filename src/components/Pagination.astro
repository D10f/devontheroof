---
import type { Page } from 'astro'

interface Props {
	base: string,
	page: Page
}

const { base, page } = Astro.props;
---

<nav>
	{Array.from(Array(page.lastPage)).map((_, idx) => {
		const pageNum = idx + 1;
		const currentPage = page.currentPage === pageNum;
		const href = pageNum > 1 ? `/${base}/${pageNum}` : `/${base}`;
		return (
			<a
				class:list={[ "nav-btn", { active: currentPage} ]}
				href={href}>
				{idx + 1}
			</a>
		)
	})}
</nav>

<style>
nav {
	display: flex;
	justify-content: center;
	align-items: center;
	gap: 0.5em;
	margin-block: 2em;
	max-width: 60%;
	margin-inline: auto;
}
nav a.nav-btn {
	background-color: var(--background-color-2);
	box-shadow: var(--shadow);
	border: 2px solid transparent;
	border-radius: var(--border-radius);
	padding: 0.5em 1em;

	&:hover,
	&:focus {
		background-color: var(--background-color);
		border: 2px solid var(--accent-color);
	}

	&.active {
		pointer-events: none;
		user-select: none;
		background-color: var(--accent-color);
		color: var(--background-color-2);
	}
}
</style>
